pipeline {
    agent any
    
    tools {
        jdk 'jdk17' 
        maven 'maven3' 
    }

    environment {
        
        DOCKER_IMAGE = "yashaditya1212/spring-boot-app:${BUILD_NUMBER}"
        GIT_REPO_NAME = "Jenkins_learnings"
        GIT_USER_NAME = "YashAditya1212"
        SONAR_ORG = "yashaditya1212"
    }

    stages {
        stage('Build') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    withSonarQubeEnv('sonar-server') {
                        sh "mvn sonar:sonar -Dsonar.projectKey=spring-boot-app -Dsonar.organization=${SONAR_ORG} -Dsonar.host.url=https://sonarcloud.io"
                    }
                }
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
                    script {
                        sh "docker build -t ${DOCKER_IMAGE} ."
                        withCredentials([usernamePassword(credentialsId: 'docker-cred', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                            sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                            sh "docker push ${DOCKER_IMAGE}"
                        }
                    }
                }
            }
        }

        stage('Update Kubernetes Manifest') {
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                        git config user.email "jenkins@example.com"
                        git config user.name "Jenkins CI"
                        
                        # Go to the manifests folder
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests
                        
                        # Replace the old image tag with the new one
                        sed -i "s|image: .*|image: ${DOCKER_IMAGE}|g" deployment.yml
                        
                        # Commit and push
                        git add deployment.yml
                        git commit -m "Update image to ${DOCKER_IMAGE} via Jenkins"
                        git remote set-url origin https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git
                        git push origin main
                    '''
                }
            }
        }
    }
}
